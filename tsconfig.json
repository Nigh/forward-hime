{
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": "src",
		"outDir": "lib",
		"target": "es2022",
		"module": "NodeNext",
		"declaration": true,
		"composite": true,
		"incremental": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"moduleResolution": "NodeNext",
		"jsx": "react-jsx",
		"jsxImportSource": "@satorijs/element",
		"types": ["node"]
	},
	"include": ["src"]
}
