{
	"name": "koishi-plugin-forward-hime",
	"description": "多群组消息互通",
	"version": "1.4.0",
	"author": {
		"name": "xianii",
		"email": "jiyucheng007@gmail.com"
	},
	"main": "lib/index.js",
	"typings": "lib/index.d.ts",
	"files": [
		"lib"
	],
	"koishi": {
		"browser": true
	},
	"license": "MIT",
	"homepage": "https://nigh.github.io/forward-hime/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nigh/forward-hime.git"
	},
	"bugs": {
		"url": "https://github.com/Nigh/forward-hime/issues"
	},
	"keywords": [
		"chatbot",
		"koishi",
		"plugin",
		"koishi-plugin",
		"forward",
		"message-forwarding"
	],
	"peerDependencies": {
		"koishi": "^4.18.7"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@koishijs/cache": "^2.0.0",
		"@types/node": "^22.15.0",
		"@typescript-eslint/eslint-plugin": "^7.13.0",
		"@typescript-eslint/parser": "^7.13.0",
		"esbuild": "^0.25.9",
		"eslint": "^9.4.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-prettier": "^5.1.3",
		"eslint-plugin-unused-imports": "^4.0.0",
		"husky": "^9.0.11",
		"koishi": "^4.18.7",
		"lint-staged": "^15.2.7",
		"prettier": "^3.3.2",
		"typescript": "~5.4.5",
		"typescript-eslint": "^8.62.0"
	},
	"scripts": {
		"prepare": "husky",
		"build": "rm -f tsconfig.tsbuildinfo && rm -rf lib && tsc -b && esbuild src/index.ts --bundle --platform=node --packages=external --outfile=lib/index.js",
		"eslint": "eslint \"src/**/*.{ts,tsx}\"",
		"format": "prettier --write .",
		"pub": "npm publish --access public"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,scss,md}": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	}
}
